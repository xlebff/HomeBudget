@page "/login"
@using System.Net.Http.Json
@using HomeBudgetShared.Contracts
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Services.TokenStorageService TokenStorage

<div>
    <h3>Вход</h3>
    <div>
        <label>Логин:</label>
        <input @bind="login" />
    </div>
    <div>
        <label>Пароль:</label>
        <input @bind="password" type="password" />
    </div>
    <button @onclick="LoginAsync">Войти</button>
    <div>@message</div>
    <div>@token</div>
</div>

@code {
    private string login = "";
    private string password = "";
    private string message = "";
    private string token = "";

    private async Task LoginAsync()
    {
        message = "";
        try
        {
            var response = await Http.PostAsJsonAsync("http://localhost:5284/api/auth/login", new { login, password });

            if (response.IsSuccessStatusCode)
            {
                var loginResponse = await response.Content.ReadFromJsonAsync<AuthResponse>();

                if (loginResponse != null && !string.IsNullOrEmpty(loginResponse.Token))
                {
                    await TokenStorage.SaveTokenAsync(loginResponse.Token);
                    token = loginResponse.Token;
                    message = "Успешный вход!";
                    Navigation.NavigateTo("/transactions");
                }
                else
                {
                    message = "Ошибка: сервер не вернул токен";
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                message = $"Ошибка входа: {error}";
            }
        }
        catch (Exception ex)
        {
            message = $"Ошибка: {ex.Message}";
        }
    }
}