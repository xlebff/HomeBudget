@page "/login"
@using System.Net.Http.Json
@using HomeBudgetShared.Contracts
@using HomeBudgetClient.Resources
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Services.TokenStorageService TokenStorage
@inject Services.AuthService AuthService

<body>
    <main>
        <section class="login-section">
            <h1 class="login-section__title">@ClientMessages.UI_LoginTitle</h1>

            <form class="login-section__form">
                <input class="login-section__form__login"
                       placeholder=@ClientMessages.UI_Login
                       type="email"
                       maxlength="100"
                       @bind="login">

                <input class="login-section__form__password"
                       placeholder=@ClientMessages.UI_Password
                       type="password"
                       maxlength="100"
                       @bind="password">
            </form>

            <button class="login-section__login-button"
                    @onclick="LoginAsync"
                    disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>@ClientMessages.UI_Loading</span>
                    }
                    else
                    {
                        <span>@ClientMessages.UI_GetStarted</span>
                    }
            </button>
        </section>
    </main>
</body>

@code {
    private string login = "";
    private string password = "";
    private string message = "";
    private bool isLoading = false;

    private async Task LoginAsync()
    {
        if (isLoading) return;
        isLoading = true;
        message = "";

        try
        {
            var response = await Http.PostAsJsonAsync("auth/login", new { login, password });

            if (response.IsSuccessStatusCode)
            {
                var loginResponse = await response.Content.ReadFromJsonAsync<AuthResponse>();

                if (loginResponse != null && !string.IsNullOrEmpty(loginResponse.Token))
                {
                    await TokenStorage.SaveTokenAsync(loginResponse.Token, loginResponse.UserId);
                    await AuthService.AddUserAsync(loginResponse.UserId, loginResponse.Login);

                    Navigation.NavigateTo("/");
                }
                else
                {
                    message = ClientMessages.Error_TokenGenerate;
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                message = String.Format(
                            ClientMessages.Error_LoginError,
                            error);
            }
        }
        catch (Exception ex)
        {
            message = String.Format(
                ClientMessages.Error_LoginError,
                ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}